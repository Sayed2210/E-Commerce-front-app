{
  "name": "ecommerce-front-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=4096 nuxt build",
    "dev": "NODE_OPTIONS=--max-old-space-size=4096 nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:styles": "stylelint \"app/**/*.{vue,css,scss}\"",
    "lint:styles:fix": "stylelint \"app/**/*.{vue,css,scss}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tokens:sync": "node scripts/sync-tokens.js",
    "tokens:check": "node scripts/sync-tokens.js --check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.vue": [
      "eslint --fix",
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/test-utils": "^3.22.0",
    "@nuxt/ui": "^4.4.0",
    "@pinia/nuxt": "^0.11.3",
    "@unhead/vue": "^2.1.1",
    "@vueuse/core": "^14.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-prettier": "^5.5.5",
    "nuxt": "^4.2.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@vitest/ui": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.2",
    "sass": "^1.99.0",
    "stylelint": "^17.7.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-scss": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
